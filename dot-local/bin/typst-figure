#!/bin/sh
# Figure manager for typst. Called from nvim with a figure path: creates the
# SVG from a blank Inkscape template if it doesn't exist yet, then opens it in
# Inkscape for editing. The figure is referenced from the typst document with
# image("fig/<doc>/<label>.svg") and re-renders live in the tinymist preview.

SVG_PATH="$1"
[ -n "$SVG_PATH" ] || { echo "usage: typst-figure <path.svg>" >&2; exit 1; }

mkdir -p "$(dirname "$SVG_PATH")"

if [ ! -e "$SVG_PATH" ]; then
	cat <<'EOF' > "$SVG_PATH"
<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<svg
   width="160mm"
   height="80mm"
   viewBox="0 0 160 80"
   version="1.1"
   xmlns:inkscape="http://www.inkscape.org/namespaces/inkscape"
   xmlns:sodipodi="http://sodipodi.sourceforge.net/DTD/sodipodi-0.dtd"
   xmlns="http://www.w3.org/2000/svg"
   xmlns:svg="http://www.w3.org/2000/svg">
  <sodipodi:namedview id="namedview1" inkscape:document-units="mm" />
  <defs id="defs1" />
  <g inkscape:label="Layer 1" inkscape:groupmode="layer" id="layer1" />
</svg>
EOF
fi

inkscape "$SVG_PATH" &
