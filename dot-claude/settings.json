{
  "model": "opus[1m]",
  "theme": "dark-ansi",
  "editorMode": "vim",
  "syntaxHighlightingDisabled": false,
  "skipDangerousModePermissionPrompt": true,
  "outputStyle": "candid",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "steveyegge/beads"
      }
    }
  },
  "mcpServers": {
    "mermaid": {
      "command": "claude-mermaid"
    }
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c \"exec $HOME/.claude/hooks/statusline.sh\""
  },
  "permissions": {
    "allow": [
      "Bash(tmux:*)",
      "Bash(/home/bryn/.claude/bin/handoff.sh:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c \"exec $HOME/.claude/hooks/simple-drift.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
